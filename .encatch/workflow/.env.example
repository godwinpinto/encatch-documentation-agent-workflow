# Cursor Agent SDK
CURSOR_API_KEY=cursor_...

# GitHub API (issues, comments, labels, PRs)
GITHUB_TOKEN=ghp_...

# Webhook signature verification
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Optional overrides
PORT=8787
GITHUB_OWNER=encatch
GITHUB_REPO=encatch-agentic-workflow
AGENT_MODEL=composer-2.5

# Comma-separated GitHub usernames or numeric user IDs to @mention when a fix is too complex
GITHUB_USER_APPROVAL=godwinpinto
