# Cursor Agent SDK
CURSOR_API_KEY=cursor_...

# GitHub auth — use GitHub App (recommended) OR personal access token (local dev)
# GitHub App (bot identity for comments, labels, PRs)
GITHUB_APP_ID=
# Private key — use ONE of:
#   GITHUB_APP_PRIVATE_KEY_PATH  file path (relative to repo root, or absolute)
#   GITHUB_APP_PRIVATE_KEY       inline PEM (use \\n for newlines; good for Docker/secrets managers)
GITHUB_APP_PRIVATE_KEY_PATH=.encatch/workflow/github-app.private-key.pem
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GITHUB_APP_INSTALLATION_ID=   # optional — auto-detected from repo

# Personal access token (fallback when GITHUB_APP_ID is unset)
# GITHUB_TOKEN=ghp_...

# Webhook signature verification (same secret as GitHub App webhook)
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Optional overrides
PORT=8787
GITHUB_OWNER=godwinpinto
GITHUB_REPO=encatch-documentation-agent-workflow
AGENT_MODEL=composer-2.5

# Comma-separated GitHub usernames or numeric user IDs to @mention when a fix is too complex
GITHUB_USER_APPROVAL=godwinpinto

# Used by `pnpm setup:github-app` to pre-fill webhook URL
# WEBHOOK_URL=https://your-ngrok-url.ngrok-free.app/webhooks/github
